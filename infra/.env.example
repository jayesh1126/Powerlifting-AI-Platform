# Compose-level configuration (secrets for the services themselves live in
# web/.env and orchestrator/.env, loaded via env_file).

# "local" (plain :80) or "prod" (TLS for powerlifting-ai.com)
CADDY_ENV=local

# Published caddy ports — override when 80/443 are taken on the host.
HTTP_PORT=80
HTTPS_PORT=443

# Baked into the web client bundle at build time (public values).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# OpenPowerlifting Postgres (never published outside the docker network).
OPL_POSTGRES_USER=opl
OPL_POSTGRES_PASSWORD=change-me
OPL_POSTGRES_DB=openpowerlifting

# Host folder containing openipf-latest.csv for the one-shot data load.
OPL_IMPORT_DIR=./opl/import

IMAGE_TAG=latest