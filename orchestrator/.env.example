# Shared secret — must match ORCHESTRATOR_API_KEY in web/.env
INTERNAL_API_KEY=dev-secret-change-me

# --- LLM providers ----------------------------------------------------------
# Chat models (planner / generator / summarizer) via OpenRouter.
# Without this the runtime runs in stub mode (heuristic planner, echo answer).
# OPENROUTER_API_KEY=
# Embeddings for retrieval — must match the model that embedded the knowledge
# base (text-embedding-3-large). Falls back to OpenRouter if unset.
# OPENAI_API_KEY=

# Override model roles (defaults in app/config.py):
# PLANNER_MODEL=meta-llama/llama-3.1-8b-instruct
# GENERATOR_MODEL=openai/gpt-4.1-nano
# SUMMARIZER_MODEL=meta-llama/llama-3.1-8b-instruct

# --- Data stores --------------------------------------------------------------
# Supabase project (pgvector knowledge base) — needed for retrieval.
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=

# OpenPowerlifting meet-results Postgres (read-only; same docker network in
# deployment). Load it with infra/opl/init.sql.
# OPL_DATABASE_URL=postgresql://opl:opl@localhost:5433/openpowerlifting

# --- Logging ------------------------------------------------------------------
# INFO logs are content-free; set DEBUG locally to see queries/tool args.
# LOG_LEVEL=INFO
# "json" in production (docker compose sets this) so logs match the web service.
# LOG_FORMAT=text
