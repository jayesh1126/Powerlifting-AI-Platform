# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret (service role) key — server only, bypasses RLS
SUPABASE_SECRET_KEY=sb_secret_...

# AES-256-GCM key for encrypting chat content at rest.
# Must match the old app's key to read existing rows.
# Generate a new one with: openssl rand -base64 32
ENCRYPTION_KEY=

# Python orchestrator service
ORCHESTRATOR_URL=http://localhost:8000
# Shared secret — must match INTERNAL_API_KEY in orchestrator/.env
ORCHESTRATOR_API_KEY=dev-secret-change-me
